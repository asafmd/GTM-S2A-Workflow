    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n// 1. Get the raw text from the Gemini output\nconst rawText = $input.first().json.candidates[0].content.parts[0].text ;\n\ntry {\n  // 2. Use Regex to find the first { and last } to extract the JSON block\n  // This ignores backticks, \"json\" labels, or any conversational filler\n  const jsonMatch = rawText.match(/\\{[\\s\\S]*\\}/);\n\n  if (!jsonMatch) {\n    throw new Error(\"No JSON found in model response\");\n  }\n\n  // 3. Parse the cleaned string\n  const data = JSON.parse(jsonMatch[0]);\n\n  // 4. Return the clean keys for your next nodes\n  return {\n    lead_tier: data.lead_tier,\n    personalized_hook: data.personalized_hook,\n    raw_status: \"Success\"\n  };\n\n} catch (error) {\n  // 5. Error handling: If it fails, return the error so the workflow doesn't just crash\n  return {\n    lead_tier: \"Error\",\n    personalized_hook: \"Manual review required: Formatting error.\",\n    raw_status: \"Failed\",\n    error_message: error.message\n  };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        160
      ],
      "id": "2461b780-6579-4033-8085-02a1aa5bb4e9",
      "name": "Split Lead Tier and Personalized message"
    },
    {
      "parameters": {
        "jsCode": "// Get the company name\nlet company = $input.first().json.fields.Company|| \"\"; \n\nif (company) {\n  // 1. Clean whitespace first\n  company = company.trim();\n\n  /**\n   * SMART REGEX EXPLAINED:\n   * \\s+          -> Matches one or more spaces before the suffix\n   * (llc|pvt|ltd|pte|pty|inc|corp|limited) -> The list of suffixes to kill\n   * \\.?          -> Matches an optional period (e.g., \"Ltd.\")\n   * $            -> Anchors the match to the very END of the string\n   * i            -> Case-insensitive\n   */\n  const suffixRegex = /\\s+(llc|pvt|ltd|pte|pty|inc|corp|limited)\\.?$/i;\n\n  // 2. Remove the suffix if it's at the end\n  // We run this in a loop just in case a name has double suffixes like \"Company Pvt Ltd\"\n  while (suffixRegex.test(company)) {\n    company = company.replace(suffixRegex, \"\").trim();\n  }\n\n  // 3. Title Case for professional formatting\n  company = company.toLowerCase().split(' ')\n    .map(word => word.charAt(0).toUpperCase() + word.slice(1))\n    .join(' ');\n}\n\nreturn {\n  normalized_name: company\n};"
      },
